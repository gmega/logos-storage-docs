---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

const sidebarLinks = [
  { heading: 'API Reference', items: [
    { label: 'Module API', href: '/docs/module-api/' },
    { label: 'libstorage API', href: '/docs/libstorage-api/' },
  ]},
  { heading: 'Tutorials', items: [
    { label: 'Module API Tutorial', href: '/docs/tutorial-module/' },
    { label: 'libstorage Tutorial', href: '/docs/tutorial-libstorage/' },
  ]},
  { heading: 'More', items: [
    { label: 'Resources', href: '/resources/' },
  ]},
];
---

<BaseLayout title={`${title} - Logos Storage`} description={description}>
  <Header />
  <div class="flex-1 max-w-6xl mx-auto px-6 py-10 w-full">
    <div class="flex gap-10">
      <aside class="hidden lg:block w-56 shrink-0">
        <nav class="sticky top-24 space-y-6">
          {sidebarLinks.map(section => (
            <div>
              <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">{section.heading}</h4>
              <ul class="space-y-1">
                {section.items.map(item => (
                  <li>
                    <a href={item.href} class={`block text-sm py-1 transition-colors ${currentPath === item.href ? 'text-accent-light font-medium' : 'text-muted hover:text-slate-100'}`}>
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>
      <main class="flex-1 min-w-0">
        <article class="docs-content">
          <slot />
        </article>
      </main>
    </div>
  </div>
  <Footer />
</BaseLayout>
