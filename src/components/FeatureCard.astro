---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-surface border border-white/10 rounded-xl p-6 hover:border-accent/30 transition-colors">
  <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4 text-accent-light text-xl">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-semibold text-slate-100 mb-2">{title}</h3>
  <p class="text-sm text-muted leading-relaxed">{description}</p>
</div>
