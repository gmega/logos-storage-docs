---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Docs', href: '/docs/module-api/', children: [
    { label: 'Module API Reference', href: '/docs/module-api/' },
    { label: 'libstorage API Reference', href: '/docs/libstorage-api/' },
    { label: 'Module API Tutorial', href: '/docs/tutorial-module/' },
    { label: 'libstorage Tutorial', href: '/docs/tutorial-libstorage/' },
  ]},
  { label: 'Resources', href: '/resources/' },
];
---

<header class="border-b border-white/10 bg-bg/80 backdrop-blur-md sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 text-lg font-semibold hover:text-accent-light transition-colors">
      <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="6" fill="#0d9488" fill-opacity="0.15"/>
        <path d="M8 10h6v12H8zM18 10h6v4h-6zM18 18h6v4h-6z" fill="#0d9488"/>
      </svg>
      Logos Storage
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        link.children ? (
          <div class="relative group">
            <button class={`text-sm font-medium transition-colors hover:text-accent-light ${currentPath.startsWith('/docs') ? 'text-accent-light' : 'text-muted'}`}>
              {link.label}
              <svg class="inline w-3.5 h-3.5 ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="bg-surface border border-white/10 rounded-lg py-2 min-w-[220px] shadow-xl">
                {link.children.map(child => (
                  <a href={child.href} class={`block px-4 py-2 text-sm transition-colors hover:bg-white/5 ${currentPath === child.href ? 'text-accent-light' : 'text-muted hover:text-slate-100'}`}>
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={link.href} class={`text-sm font-medium transition-colors hover:text-accent-light ${currentPath === link.href ? 'text-accent-light' : 'text-muted'}`}>
            {link.label}
          </a>
        )
      ))}
      <a href="https://github.com/logos-co" target="_blank" rel="noopener" class="text-muted hover:text-slate-100 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>

    <button id="mobile-menu-btn" class="md:hidden text-muted hover:text-slate-100 transition-colors">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-bg px-6 py-4">
    {navLinks.map(link => (
      link.children ? (
        <div class="py-2">
          <div class="text-sm font-medium text-slate-100 mb-2">{link.label}</div>
          {link.children.map(child => (
            <a href={child.href} class="block py-1.5 pl-4 text-sm text-muted hover:text-accent-light transition-colors">{child.label}</a>
          ))}
        </div>
      ) : (
        <a href={link.href} class="block py-2 text-sm font-medium text-muted hover:text-accent-light transition-colors">{link.label}</a>
      )
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
