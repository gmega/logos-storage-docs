---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<BaseLayout title="Logos Storage - Decentralized, Censorship-Resistant Storage">
  <Header />
  <Hero />

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-center mb-4">What is Logos Storage?</h2>
    <p class="text-muted text-center max-w-2xl mx-auto mb-12 leading-relaxed">
      Logos Storage is the storage layer in the Logos stack. It provides a basic filesharing layer,
      not unlike IPFS or Bittorrent, allowing users to publish and share files with one another
      in a fully decentralized manner.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <FeatureCard
        title="Decentralized"
        description="No central servers or single points of failure. Files are shared peer-to-peer across the network, making the system resilient to outages and attacks."
        icon='<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="5" r="2" stroke-width="1.5"/><circle cx="5" cy="19" r="2" stroke-width="1.5"/><circle cx="19" cy="19" r="2" stroke-width="1.5"/><path stroke-width="1.5" d="M12 7v4m-5.5 4.5L10 13m4 0l3.5 4.5"/></svg>'
      />
      <FeatureCard
        title="Censorship-Resistant"
        description="Content lives across the network and cannot be taken down by any single entity. Logos Storage is designed to resist censorship at every level."
        icon='<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-width="1.5" stroke-linecap="round" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>'
      />
      <FeatureCard
        title="Anonymous"
        description="Moving forward, Logos Storage will enable full provider and downloader anonymity, as well as anonymous persistence. Check the roadmap for more details."
        icon='<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-width="1.5" stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>'
      />
    </div>
  </section>

  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-2xl font-bold text-center mb-12">Get Started</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="https://github.com/logos-co/logos-storage-ui" target="_blank" rel="noopener" class="bg-surface border border-white/10 rounded-xl p-6 hover:border-accent/30 transition-colors group">
          <h3 class="text-lg font-semibold text-slate-100 mb-2 group-hover:text-accent-light transition-colors">UI App</h3>
          <p class="text-sm text-muted leading-relaxed">Download the Logos Storage desktop application &mdash; the easiest way to try out Logos Storage.</p>
        </a>
        <a href="/docs/tutorial-module/" class="bg-surface border border-white/10 rounded-xl p-6 hover:border-accent/30 transition-colors group">
          <h3 class="text-lg font-semibold text-slate-100 mb-2 group-hover:text-accent-light transition-colors">Tutorials</h3>
          <p class="text-sm text-muted leading-relaxed">Learn how to build applications on top of Logos Storage with our step-by-step guides.</p>
        </a>
        <a href="/docs/module-api/" class="bg-surface border border-white/10 rounded-xl p-6 hover:border-accent/30 transition-colors group">
          <h3 class="text-lg font-semibold text-slate-100 mb-2 group-hover:text-accent-light transition-colors">API Docs</h3>
          <p class="text-sm text-muted leading-relaxed">Explore the Module API and libstorage API references for full technical details.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 bg-accent/5">
    <div class="max-w-6xl mx-auto px-6 py-12 text-center">
      <p class="text-muted mb-4">Logos Storage is under active development. Check out our roadmap to see what's coming next.</p>
      <a href="https://roadmap.logos.co/storage/roadmap/" target="_blank" rel="noopener" class="inline-flex items-center text-accent-light hover:underline font-medium">
        View Roadmap
        <svg class="ml-1 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
